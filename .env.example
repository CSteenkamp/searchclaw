# SearchClaw Environment Variables

# App
DEBUG=true
APP_NAME=SearchClaw
APP_VERSION=0.1.0

# Security
API_KEY_HMAC_SECRET=change-me-to-a-random-secret
CORS_ORIGINS=["https://searchclaw.dev","http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://searchclaw:searchclaw@localhost:5432/searchclaw

# Redis
REDIS_URL=redis://localhost:6379/0

# SearXNG
SEARXNG_URLS=["http://localhost:8888"]
SEARXNG_TIMEOUT=10.0

# Browser pool (spec 2)
BROWSER_POOL_SIZE=3
BROWSER_TIMEOUT=30000

# LLM (spec 2)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_FALLBACK_MODEL=claude-3-haiku-20240307

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare
CF_API_TOKEN=
CF_ZONE_ID=

# Hetzner Cloud (VPS provisioning)
HETZNER_API_TOKEN=

# SearXNG external nodes
SEARXNG_AUTH_TOKEN=

# Cache warming
SEARCHCLAW_API_URL=http://localhost:8000
SEARCHCLAW_API_KEY=
